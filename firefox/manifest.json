{
  "manifest_version": 3,
  "name": "FatCatTuxedo's Imgur Proxy",
  "description": "Redirects Imgur image URLs to a proxy to bypass region blocks and censorship.",
  "version": "1",
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
    "browser_specific_settings": {
    "gecko": {
        "id": "@fatcattuxedo-imgur-proxy-extension",
        "data_collection_permissions": {
          "required": ["none"]
         }
      }
  },
  "declarative_net_request": {
    "rule_resources": [{
      "id": "ruleset_1",
      "enabled": true,
      "path": "rules.json"
    }]
  },
  "icons": {
    "128": "images/icon-128.png",
    "96": "images/icon-96.png"
  }
}